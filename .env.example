# ============================================================
# 링글 AI 튜터 환경변수 예시
# 실제 사용 시: 이 파일을 복사하여 .env (backend) / .env.local (frontend) 생성
# ============================================================

# ── Backend (ringle-backend/.env) ──────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/ringle_development
OPENAI_API_KEY=sk-...your-openai-api-key-here
RAILS_ENV=development
RAILS_LOG_TO_STDOUT=true

# ── Frontend (ringle-frontend/.env.local) ──────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
# 개발/데모용 임시 user_id (실제 서비스에서는 JWT 인증으로 교체)
NEXT_PUBLIC_USER_ID=1
